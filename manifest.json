{
  "manifest_version": 3,
  "name": "DualSub - YouTube Song Ngữ Anh Việt",
  "version": "1.0.0",
  "description": "Hiển thị phụ đề song ngữ Anh-Việt trên YouTube giúp học tiếng Anh qua các khóa học như CS231n, CS50, MIT OpenCourseWare và nhiều hơn nữa.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://youtubetranscript.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DualSub - Phụ đề song ngữ",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
