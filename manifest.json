{
  "manifest_version": 3,
  "name": "DualSub - Học tiếng Anh qua phụ đề song ngữ",
  "version": "2.0.0",
  "description": "Phụ đề song ngữ Anh-Việt + từ điển + flashcard + transcript đồng bộ. Học tiếng Anh qua CS231n, CS50, MIT OpenCourseWare và nhiều hơn nữa.",
  "permissions": [
    "storage",
    "activeTab",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.coursera.org/*",
    "https://*.edx.org/*",
    "https://*.udemy.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://youtubetranscript.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DualSub - Phụ đề song ngữ",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.coursera.org/*",
        "https://coursera.org/*",
        "https://www.edx.org/*",
        "https://edx.org/*",
        "https://www.udemy.com/*",
        "https://udemy.com/*"
      ],
      "js": [
        "content/bootstrap.js",
        "content/platform.js",
        "content/dictionary.js",
        "content/vocabulary.js",
        "content/transcript.js",
        "content/highlight.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css",
        "content/dictionary.css",
        "content/transcript.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [{
    "resources": ["content/*", "icons/*"],
    "matches": ["https://*.youtube.com/*", "https://*.coursera.org/*", "https://*.edx.org/*", "https://*.udemy.com/*"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
